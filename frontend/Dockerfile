# ============================================================
# Dockerfile для Vue.js фронтенду.
#
# Використовуємо двоетапну збірку:
# Етап 1 (builder) — встановлює Node.js і збирає Vue в статичні файли.
# Етап 2 (nginx)   — бере тільки зібрані файли і роздає їх через nginx.
#
# Фінальний образ містить тільки nginx + статичні файли.
# Node.js і node_modules в нього НЕ потрапляють — образ набагато менший.
# ============================================================

# ===== Етап 1: збірка фронтенду =====
# node:20-alpine — мінімальний образ Node.js 20 на основі Alpine Linux.
# Alpine набагато менший за Debian/Ubuntu (5 МБ проти 100+ МБ).
FROM node:20-alpine AS builder

# Робоча директорія для збірки
WORKDIR /app

# Спочатку копіюємо тільки package.json для кешування npm install.
# Якщо залежності не змінились — Docker використає кеш.
COPY package.json .

# Встановлюємо всі npm-залежності.
# --frozen-lockfile — встановлювати точно ті версії що в package-lock.json.
RUN npm install

# Копіюємо весь код фронтенду
COPY . .

# Збираємо Vue-застосунок для продакшену.
# Vite створює папку dist/ з оптимізованими статичними файлами:
# HTML, CSS, JavaScript (мінімізований і об'єднаний у бандли).
RUN npm run build

# ===== Етап 2: роздача статичних файлів =====
# Беремо чистий образ nginx — без Node.js і node_modules.
FROM nginx:alpine

# Копіюємо зібрані статичні файли з першого етапу (builder)
# в папку де nginx роздає файли за замовчуванням.
COPY --from=builder /app/dist /usr/share/nginx/html

# Копіюємо нашу конфігурацію nginx.
# Вона замінює стандартну конфігурацію nginx.
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Nginx слухає на порту 80 всередині контейнера
EXPOSE 80

# nginx запускається автоматично — команда не потрібна,
# базовий образ nginx вже містить відповідний CMD.
