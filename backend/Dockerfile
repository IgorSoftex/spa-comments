# ============================================================
# Dockerfile для Django-бекенду.
#
# Використовуємо багатоетапну збірку (multi-stage build):
# Це дозволяє зменшити розмір фінального образу — в нього
# потрапляє тільки те що потрібно для запуску, без зайвих
# інструментів збірки.
# ============================================================

# --- Етап 1: базовий образ ---
# python:3.11-slim — мінімальний образ Python 3.11 на основі Debian.
# slim означає що видалені зайві пакети — образ менший за розміром.
FROM python:3.11-slim

# Встановлюємо змінні середовища для Python:
# PYTHONDONTWRITEBYTECODE=1 — не створювати .pyc файли (кешовані байткоди).
#   В контейнері вони не потрібні і тільки займають місце.
# PYTHONUNBUFFERED=1 — виводити логи одразу без буферизації.
#   Без цього логи Django можуть не з'являтись в docker logs.
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Встановлюємо системні залежності.
# libpq-dev    — бібліотека для PostgreSQL (на майбутнє)
# gcc          — компілятор C (потрібен для деяких Python-пакетів)
# --no-install-recommends — не встановлювати рекомендовані пакети,
#   тільки необхідні. Зменшує розмір образу.
# rm -rf /var/lib/apt/lists/* — видаляємо кеш apt після встановлення.
#   Це зменшує розмір шару Docker-образу.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libpq-dev \
        gcc \
    && rm -rf /var/lib/apt/lists/*

# Встановлюємо робочу директорію всередині контейнера.
# Всі наступні команди виконуватимуться відносно /app.
WORKDIR /app

# Спочатку копіюємо тільки requirements.txt і встановлюємо залежності.
# Чому не копіювати весь код одразу?
# Docker кешує кожен шар (layer). Якщо requirements.txt не змінився,
# Docker використає кеш і не буде перевстановлювати пакети.
# Це значно прискорює повторні збірки.
COPY requirements.txt .
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# Тепер копіюємо весь код бекенду в контейнер.
# Цей шар змінюється при кожній зміні коду,
# але pip install вже закешований і не повторюється.
COPY . .

# Збираємо статичні файли Django в папку staticfiles/.
# WhiteNoise роздаватиме їх без окремого nginx для статики.
# --noinput — не запитувати підтвердження.
RUN python manage.py collectstatic --noinput

# Порт на якому слухає Daphne всередині контейнера.
# EXPOSE не відкриває порт назовні — це тільки документація.
# Реальне відкриття портів робить docker-compose.
EXPOSE 8000

# Команда запуску при старті контейнера.
# Daphne — ASGI-сервер який підтримує HTTP і WebSocket.
# -b 0.0.0.0 — слухати на всіх мережевих інтерфейсах контейнера.
# -p 8000    — порт всередині контейнера.
# config.asgi:application — шлях до ASGI-застосунку.
CMD ["daphne", "-b", "0.0.0.0", "-p", "8000", "config.asgi:application"]
